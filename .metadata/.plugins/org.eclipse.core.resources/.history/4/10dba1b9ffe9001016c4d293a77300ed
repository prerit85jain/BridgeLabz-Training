package studentCourseRegistrationSystem;

import java.util.*;
import java.util.ArrayList;
import java.util.List;

public class Main {
	private static int totalStudent = 0;
	static {
		System.out.println("Welcome to Student Registration Portal");
	}
	public static void showOptions() {
		System.out.println("\nSelect option:");
		System.out.println("1. Register Student");
		System.out.println("2. Details");
		System.out.println("3. Update Information");
		System.out.println("4. Withdraw Student");
		System.out.println("5. Exit");
		System.out.print("Enter Choice: ");
	}
	public static void showCourseOption() {
		System.out.println("Course Option:");
		System.out.println("B.Tech\nM.Tech\nBCA\nMCA");
	}
	public static void main(String[] args) {
		List<Student> students = new ArrayList<>();
		Scanner scanner = new Scanner(System.in);
		while(true) {
			showOptions();
			int choice = scanner.nextInt();
			if (choice == 5) {
				break;
			}
			switch(choice) {
			case 1:
				showCourseOption();
				int rollNo = ++totalStudent;
				scanner.next();
				System.out.print("Enter Name: ");
				String name = scanner.nextLine();
				System.out.print("Enter course: ");
				String course = scanner.nextLine();
				System.out.print("Enter Grade: ");
				String grade = scanner.nextLine();
				students.add(new Student(rollNo, name, course, grade));
				break;
			case 2:
				System.out.println("All Students: ");
				for(Student std : students) {
					System.out.println(std);
				}
			}
		}
		scanner.close();
	}
}
